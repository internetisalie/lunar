# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# ktlint: this codebase is formatted by the IntelliJ formatter, not ktlint. ~53 of the standard
# rules are violated repo-wide, so the standard ruleset is disabled wholesale rather than
# maintained as a long (and ever-growing) per-rule list. `./gradlew ktlintCheck` therefore passes;
# it stays available to catch any future non-standard ruleset. To adopt a real ktlint gate later,
# run `./gradlew ktlintFormat` to reformat, then re-enable `ktlint_standard` (and commit the diff).
[*.{kt,kts}]
ktlint_standard = disabled

# Kotlin files
[*.kt]
ij_kotlin_packages_to_use_star_imports = java.util.*,kotlinx.io.Closeable
max_line_length = 120
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Kotlin script files
[*.kts]
ij_kotlin_packages_to_use_star_imports = java.util.*,kotlinx.io.Closeable
max_line_length = 120
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Properties files
[*.properties]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Gradle files
[*.gradle]
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
