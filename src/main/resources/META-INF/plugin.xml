<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
  <id>net.internetisalie.lunar</id>

  <!-- Public plugin name should be written in Title Case.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
  <name>Lunar</name>

  <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
  <vendor email="internetisalie@gmail.com" url="https://internetisalie.github.io">internetisalie</vendor>

  <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
       Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
  <description><![CDATA[
    Enhanced Lua support for JetBrains IDEs.
  ]]></description>

  <!-- Product and plugin compatibility requirements.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.coverage</depends>
  <depends>com.intellij.modules.json</depends>

  <!-- TOOL-00 de-risking spike: optional dependency on the bundled built-in terminal so the
       terminal PATH-injection customizer only loads when the terminal plugin is present.
       Keeps the terminal a soft dependency rather than bloating the base plugin. -->
  <depends optional="true" config-file="lunar-terminal.xml">org.jetbrains.plugins.terminal</depends>

  <!-- ROCKS-11: optional dependency on the marketplace JetBrains "Makefile Language" plugin so the
       scaffolded Makefile's targets are one-click runnable when present. Soft dependency: Lunar
       loads normally when the plugin is absent. -->
  <depends optional="true" config-file="lunar-makefile.xml">name.kropp.intellij.makefile</depends>

  <extensionPoints>
      <extensionPoint name="schemaFileProvider" interface="net.internetisalie.lunar.lang.schema.LuaSchemaFileProvider" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij.json">
      <jsonLikePsiWalkerFactory implementation="net.internetisalie.lunar.lang.schema.LuaJsonLikePsiWalkerFactory"/>
      <jsonSchemaEnabler implementation="net.internetisalie.lunar.lang.schema.LuaJsonSchemaEnabler"/>
  </extensions>

  <extensions defaultExtensionNs="JavaScript">
      <JsonSchema.ProviderFactory implementation="net.internetisalie.lunar.lang.schema.LuaSchemaProviderFactory"/>
  </extensions>

  <!-- SCHEMA-02: rockspec schema providers, contributed to the SCHEMA-01 engine's own EP. The
       LuaSchemaProviderFactory above returns these to the platform JSON-Schema engine. -->
  <extensions defaultExtensionNs="net.internetisalie.lunar">
      <schemaFileProvider implementation="net.internetisalie.lunar.lang.schema.providers.RockspecSchemaProvider$V30"/>
      <schemaFileProvider implementation="net.internetisalie.lunar.lang.schema.providers.RockspecSchemaProvider$V31"/>
      <!-- SCHEMA-03: luacheck config -->
      <schemaFileProvider implementation="net.internetisalie.lunar.lang.schema.providers.LuacheckrcSchemaProvider"/>
      <schemaFileProvider implementation="net.internetisalie.lunar.lang.schema.providers.BustedSchemaProvider"/>
  </extensions>

  <!-- Extension points defined by the plugin.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
  <extensions defaultExtensionNs="com.intellij">

    <!-- LuaRocks project generator (ROCKS-01) -->
    <directoryProjectGenerator
            implementation="net.internetisalie.lunar.rocks.init.LuaRocksProjectGenerator"/>

    <!-- LuaRocks dependency tool window (ROCKS-03) -->
    <toolWindow
            id="LuaRocks"
            anchor="right"
            secondary="true"
            icon="net.internetisalie.lunar.lang.LuaIcons.ROCKET"
            factoryClass="net.internetisalie.lunar.rocks.ui.LuaRocksToolWindowFactory"/>

    <!-- LuaRocks Package Browser (ROCKS-02) -->
    <toolWindow
            id="LuaRocks Packages"
            anchor="bottom"
            icon="net.internetisalie.lunar.lang.LuaIcons.ROCKET"
            factoryClass="net.internetisalie.lunar.rocks.browser.LuaRocksPackageBrowserToolWindowFactory"/>



    <!-- Language -->

    <fileType
            name="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaFileType"
            fieldName="INSTANCE"
            language="Lua"
            extensions="lua;rockspec"
            fileNames=".luacheckrc;.busted"/>

    <fileType
            name="Lua Workspace"
            implementationClass="net.internetisalie.lunar.lang.LuaWorkFileType"
            fieldName="INSTANCE"
            language="Lua"
            extensions="luawork"/>

    <lang.syntaxHighlighterFactory
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaSyntaxHighlighterFactory"/>

    <lang.parserDefinition
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaParserDefinition"/>

    <!-- Surround With (Ctrl+Alt+T): wrap statement runs in if/while/for/function/do/pcall (EDITOR-05) -->
    <lang.surroundDescriptor
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.surround.LuaStatementsSurroundDescriptor"/>

    <!-- Unwrap/Remove (Ctrl+Shift+Delete): unwrap block, collapse else, remove construct (EDITOR-06) -->
    <lang.unwrapDescriptor
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.unwrap.LuaUnwrapDescriptor"/>

    <!-- Move Statement Up/Down (Ctrl+Shift+↑/↓) — structural, block-aware (EDITOR-07-01/-02/-04).
         Application-level EP: no language attr; self-guards on LuaFile. -->
    <statementUpDownMover
            id="LuaStatementMover"
            implementation="net.internetisalie.lunar.lang.editor.LuaStatementMover"/>

    <!-- Move Element Left/Right (Ctrl+Alt+Shift+←/→) — reorder args/fields/name lists (EDITOR-07-03).
         EP name is `com.intellij.moveLeftRightHandler` (no `lang.` prefix). -->
    <moveLeftRightHandler
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.editor.LuaMoveLeftRightHandler"/>

    <!-- Smart Enter (Ctrl+Shift+Enter): complete half-written block/call, place caret (EDITOR-08) -->
    <lang.smartEnterProcessor
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.smartenter.LuaSmartEnterProcessor"/>

    <!-- Navigation: Go to Class / Symbol (NAV-03) -->
    <gotoClassContributor
            implementation="net.internetisalie.lunar.lang.navigation.LuaGotoClassContributor"/>
    <gotoSymbolContributor
            implementation="net.internetisalie.lunar.lang.navigation.LuaGotoSymbolContributor"/>

    <platform.backend.documentation.targetProvider
            order="first"
            implementation="net.internetisalie.lunar.lang.doc.LuaDocumentationTargetProvider" />

    <platform.backend.documentation.linkHandler
            implementation="net.internetisalie.lunar.lang.doc.LuaDocumentationLinkHandler"/>

    <colorSettingsPage
            implementation="net.internetisalie.lunar.lang.syntax.LuaColorSettingsPage"/>

    <codeStyleSettingsProvider
            implementation="net.internetisalie.lunar.lang.format.LuaCodeStyleSettingsProvider"/>
    <langCodeStyleSettingsProvider
            implementation="net.internetisalie.lunar.lang.format.LuaLanguageCodeStyleSettingsProvider"/>

    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaNumeralAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaLongStringAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaLongCommentAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaAttribNameAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaStandaloneExpressionAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaVarargAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.luacats.lang.syntax.LuaCatsAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaInferredTypeAnnotator"/>

    <localInspection
            language="Lua"
            displayName="Type assignability"
            groupName="Lua"
            enabledByDefault="true"
            level="ERROR"
            implementationClass="net.internetisalie.lunar.analysis.LuaTypeAssignabilityInspection"/>

    <localInspection
            language="Lua"
            displayName="Return type mismatch"
            groupName="Lua"
            enabledByDefault="true"
            level="ERROR"
            implementationClass="net.internetisalie.lunar.analysis.LuaReturnTypeMismatchInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaUndeclaredVariable"
            displayName="Undeclared variable"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaUndeclaredVariableInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaGlobalCreation"
            displayName="Global creation"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaGlobalCreationInspection"/>
        <localInspection language="Lua" shortName="LuaUnusedLocal"
            displayName="Unused local variable or parameter" groupName="Lua" enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaUnusedLocalInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaShadowingVariable"
            displayName="Shadowing variable"
            groupName="Lua"
            enabledByDefault="true"
            level="WEAK WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaShadowingVariableInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaDeprecatedApi"
            displayName="Deprecated API"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaDeprecatedApiInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaSuspiciousConcatenation"
            displayName="Suspicious concatenation"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaSuspiciousConcatenationInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaUnreachableCode"
            displayName="Unreachable code"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaUnreachableCodeInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaLanguageLevel"
            displayName="Language level compliance"
            groupName="Lua"
            enabledByDefault="true"
            level="ERROR"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaLanguageLevelInspection"/>

    <localInspection
            language="Lua"
            shortName="LuaValkeyPortability"
            displayName="Valkey-only API under Redis target"
            groupName="Lua"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="net.internetisalie.lunar.analysis.inspections.LuaValkeyPortabilityInspection"/>

    <localInspection language="Lua"
                     shortName="LuaJsonSchemaCompliance"
                     displayName="Lua JSON Schema compliance"
                     groupName="Lua"
                     enabledByDefault="true"
                     level="WARNING"
                     implementationClass="net.internetisalie.lunar.lang.schema.LuaJsonSchemaComplianceInspection"/>

    <!-- Schema-driven completion/docs flow from the JSON engine via the registered walker. These
         reference platform `…jsonSchema.impl` classes (the DR-03 fallback, since the engine does not
         auto-bind a host-language contributor); they are impl (not API) and may need revisiting on
         IDE platform upgrades. Both no-op on Lua files no provider claims (engine resolves no schema). -->
    <completion.contributor language="Lua" implementationClass="com.jetbrains.jsonSchema.impl.JsonSchemaCompletionContributor"/>
    <lang.documentationProvider language="Lua" implementationClass="com.jetbrains.jsonSchema.impl.JsonSchemaDocumentationProvider" order="first"/>

    <externalAnnotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.analysis.luacheck.LuaCheckAnnotator"/>

    <localInspection
            language="Lua"
            shortName="LuaCheck"
            displayName="LuaCheck"
            groupPath="Lua"
            groupName="Luacheck"
            enabledByDefault="true"
            level="WARNING"
            unfair="true"
            implementationClass="net.internetisalie.lunar.analysis.luacheck.LuaCheckInspection"/>

    <editorHighlighterProvider
            filetype="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaEditorHighlighterProvider"/>

    <enterHandlerDelegate implementation="net.internetisalie.lunar.lang.format.LuaEnterHandlerDelegate" />

    <psi.referenceContributor
            language="Lua"
            implementation="net.internetisalie.lunar.lang.LuaLabelReferenceContributor"/>
    <psi.referenceContributor
            language="Lua"
            implementation="net.internetisalie.lunar.lang.LuaRequireReferenceContributor"/>

    <defaultLiveTemplates file="liveTemplates/lua.xml"/>
    <liveTemplateContext implementation="net.internetisalie.lunar.lang.completion.templates.LuaTemplateContextType"/>
    <liveTemplateContext implementation="net.internetisalie.lunar.lang.completion.templates.LuaCodeContextType"/>
    <liveTemplateContext implementation="net.internetisalie.lunar.lang.completion.templates.LuaSurroundContextType"/>
    <enterHandlerDelegate implementation="net.internetisalie.lunar.lang.completion.LuaEnterHandler"/>
    <enterHandlerDelegate implementation="net.internetisalie.lunar.lang.completion.LuaEnterBetweenBlockHandler"/>
    <codeInsight.template.postfixTemplateProvider language="Lua" implementationClass="net.internetisalie.lunar.lang.completion.postfix.LuaPostfixTemplateProvider"/>
    <completion.contributor
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaCompletionContributor"/>

    <lang.findUsagesProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaFindUsagesProvider"/>
    <usageTypeProvider
            implementation="net.internetisalie.lunar.lang.insight.LuaReadWriteUsageTypeProvider"/>
    <readWriteAccessDetector
            implementation="net.internetisalie.lunar.lang.insight.LuaReadWriteAccessDetector"/>
    <referencesSearch
            implementation="net.internetisalie.lunar.lang.insight.LuaNameReferenceSearcher"/>
    <lang.refactoringSupport
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaRefactoringSupportProvider"/>
    <refactoring.safeDeleteProcessor
            implementation="net.internetisalie.lunar.refactoring.LuaSafeDeleteProcessor"/>
    <nameSuggestionProvider
            implementation="net.internetisalie.lunar.refactoring.rename.LuaNameSuggestionProvider"/>
    <lang.namesValidator
            language="Lua"
            implementationClass="net.internetisalie.lunar.refactoring.LuaNamesValidator"/>

    <lang.psiStructureViewFactory language="Lua"
                                  implementationClass="net.internetisalie.lunar.lang.structure.LuaStructureViewFactory"/>

    <lang.commenter
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.format.LuaCommenter"/>

    <lang.formatter
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.format.LuaFormattingModelBuilder" />

    <formattingService
            implementation="net.internetisalie.lunar.lang.formatting.external.StyluaFormattingService"
            order="first" />

    <!-- FORMAT-03-03: normalize the trailing newline at EOF on reformat. -->
    <postFormatProcessor
            implementation="net.internetisalie.lunar.lang.format.LuaTrailingNewlinePostProcessor" />

    <!-- FORMAT-06-02: hard-wrap over-long line comments (opt-in via WRAP_LONG_COMMENTS). -->
    <postFormatProcessor
            implementation="net.internetisalie.lunar.lang.format.LuaCommentWrapPostProcessor" />

    <lang.foldingBuilder
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaFoldingBuilder" />

    <breadcrumbsInfoProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaBreadcrumbsProvider" />

    <lang.braceMatcher
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaPairedBraceMatcher" />

    <!-- EDITOR-04: Smart Word Selection — construct-aware Extend/Shrink Selection steps -->
    <extendWordSelectionHandler
            implementation="net.internetisalie.lunar.lang.insight.LuaBlockSelectioner"/>
    <extendWordSelectionHandler
            implementation="net.internetisalie.lunar.lang.insight.LuaStringInteriorSelectioner"/>
    <extendWordSelectionHandler
            implementation="net.internetisalie.lunar.lang.insight.LuaArgumentListSelectioner"/>
    <extendWordSelectionHandler
            implementation="net.internetisalie.lunar.lang.insight.LuaCommentInteriorSelectioner"/>

    <!-- EDITOR-01: Smart Typing — quote pairing + bracket context suppression -->
    <lang.quoteHandler
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.editor.LuaQuoteHandler"/>
    <typedHandler
            implementation="net.internetisalie.lunar.lang.editor.LuaTypedHandler"/>

    <!-- EDITOR-01: Smart Typing — keyword-block auto-close Smart Keys toggle -->
    <editorSmartKeysConfigurable
            instance="net.internetisalie.lunar.lang.editor.LuaEditorOptionsConfigurable"/>

    <codeBlockSupportHandler
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaCodeBlockSupportHandler" />

    <codeInsight.parameterInfo
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.hint.LuaParameterInfoHandler" />

    <codeInsight.declarativeInlayProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.hint.LuaTypeInlayHintProvider"
            isInternal="false"
            isEnabledByDefault="true"
            group="TYPES_GROUP"
            providerId="lua.type.hints"
            bundle="net.internetisalie.lunar.LuaBundle"
            nameKey="lua.type.hints.name">
      <option bundle="net.internetisalie.lunar.LuaBundle"
              optionId="lua.local.variable.type"
              enabledByDefault="true"
              nameKey="lua.type.hints.local.variable"
              descriptionKey="lua.type.hints.local.variable.desc"/>
      <option bundle="net.internetisalie.lunar.LuaBundle"
              optionId="lua.return.type"
              enabledByDefault="false"
              nameKey="lua.type.hints.return.type"
              descriptionKey="lua.type.hints.return.type.desc"/>
      <option bundle="net.internetisalie.lunar.LuaBundle"
              optionId="lua.respect.annotations"
              enabledByDefault="true"
              nameKey="lua.type.hints.respect.annotations"
              descriptionKey="lua.type.hints.respect.annotations.desc"/>
    </codeInsight.declarativeInlayProvider>

    <codeInsight.declarativeInlayProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.hint.LuaMethodChainInlayHintProvider"
            isInternal="false"
            isEnabledByDefault="true"
            group="METHOD_CHAINS_GROUP"
            providerId="lua.method.chain.hints"
            bundle="net.internetisalie.lunar.LuaBundle"
            nameKey="lua.type.hints.method.chain">
      <option bundle="net.internetisalie.lunar.LuaBundle"
              optionId="lua.method.chain"
              enabledByDefault="true"
              nameKey="lua.type.hints.method.chain"
              descriptionKey="lua.type.hints.method.chain.desc"/>
    </codeInsight.declarativeInlayProvider>

    <codeInsight.declarativeInlayProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.hint.LuaParameterInlayHintsProvider"
            isInternal="false"
            isEnabledByDefault="true"
            group="PARAMETERS_GROUP"
            providerId="lua.parameter.hints"
            bundle="net.internetisalie.lunar.LuaBundle"
            nameKey="lua.type.hints.parameter.name"/>

    <codeInsight.declarativeInlayProviderCustomSettingsProvider
            language="Lua"
            providerId="lua.type.hints"
            implementationClass="net.internetisalie.lunar.lang.insight.hint.LuaInlayHintsCustomSettingsProvider"/>

    <additionalLibraryRootsProvider implementation="net.internetisalie.lunar.project.PlatformLibraryProvider"/>
    <additionalLibraryRootsProvider implementation="net.internetisalie.lunar.lang.library.LuaLibraryProvider"/>
    <additionalLibraryRootsProvider implementation="net.internetisalie.lunar.rocks.library.LuaRocksLibraryProvider"/>
    <projectViewNodeDecorator implementation="net.internetisalie.lunar.rocks.view.LuaRockSourceRootDecorator"/>

    <!-- Options -->
    <applicationService
            serviceImplementation="net.internetisalie.lunar.settings.LuaApplicationSettings" />
    <!-- EDITOR-01: keyword-block Smart Keys toggle state -->
    <applicationService
            serviceImplementation="net.internetisalie.lunar.settings.LuaEditorOptions" />

    <!-- Unified toolchain registry (TOOLING-01) -->
    <applicationService
            serviceImplementation="net.internetisalie.lunar.toolchain.registry.LuaToolchainRegistry" />

    <!-- Unified toolchain probe service (TOOLING-01) -->
    <applicationService
            serviceInterface="net.internetisalie.lunar.toolchain.probe.LuaToolProbe"
            serviceImplementation="net.internetisalie.lunar.toolchain.probe.LuaToolProbeImpl" />

    <!-- REDIS-04 AC-2: bundled per-version command-spec service (design §2.2, §7) -->
    <applicationService
            serviceImplementation="net.internetisalie.lunar.analysis.redis.RedisCommandSpecService" />

    <!-- Synchronize project target/language level from the effective toolchain runtime (TOOLING-02-09) -->
    <postStartupActivity
            implementation="net.internetisalie.lunar.toolchain.resolve.LuaTargetSyncStartup" />

    <!-- Offer re-registration of an orphaned Lunar-provisioned environment tree (TOOLING-04-16) -->
    <postStartupActivity
            implementation="net.internetisalie.lunar.toolchain.provision.LuaEnvRedetectionStartup" />

    <!-- Offer one-click Adopt for a detected foreign env directory (TOOLING-02-14); deduped
         against LuaEnvRedetectionStartup by skipping .lunar-env.json manifest-bearing trees -->
    <postStartupActivity
            implementation="net.internetisalie.lunar.toolchain.discovery.LuaEnvironmentDetectionStartup" />

    <projectService
            serviceInterface="net.internetisalie.lunar.lang.psi.types.LuaTypeManager"
            serviceImplementation="net.internetisalie.lunar.lang.psi.types.LuaTypeManagerImpl" />

    <applicationConfigurable
            parentId="language"
            instance="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            id="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            displayName="Lua"/>

    <applicationConfigurable
            parentId="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            instance="net.internetisalie.lunar.toolchain.ui.LuaToolchainConfigurable"
            id="net.internetisalie.lunar.toolchain.ui.LuaToolchainConfigurable"
            displayName="Toolchain"/>

    <projectConfigurable
            parentId="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            instance="net.internetisalie.lunar.toolchain.ui.LuaProjectConfigurable"
            id="net.internetisalie.lunar.toolchain.ui.LuaProjectConfigurable"
            displayName="Lua Project"
            nonDefaultProject="true"/>

    <!-- REDIS-01 Phase 3: connection model, storage & credentials -->
    <projectService
            serviceImplementation="net.internetisalie.lunar.redis.connection.LuaRedisConnectionSettings"/>
    <!-- REDIS-03 Phase 4: once-per-session flavor-mismatch warning -->
    <projectService
            serviceImplementation="net.internetisalie.lunar.redis.connection.LuaRedisFlavorWarning"/>
    <projectConfigurable
            parentId="net.internetisalie.lunar.toolchain.ui.LuaProjectConfigurable"
            instance="net.internetisalie.lunar.redis.connection.LuaRedisConnectionsConfigurable"
            id="net.internetisalie.lunar.redis.connection.LuaRedisConnectionsConfigurable"
            displayName="Redis Connections"
            nonDefaultProject="true"/>

    <configurationType
            implementation="net.internetisalie.lunar.run.LuaRunConfigurationType"/>
    <configurationType
            implementation="net.internetisalie.lunar.run.test.LuaTestRunConfigurationType"/>
    <runConfigurationProducer
            implementation="net.internetisalie.lunar.run.test.LuaTestRunConfigurationProducer"/>
    <runLineMarkerContributor
            language="Lua"
            implementationClass="net.internetisalie.lunar.run.test.LuaTestRunLineMarkerProvider"/>

    <!-- REDIS-01 Phase 5: Redis Script run configuration + target-gated producer -->
    <configurationType
            implementation="net.internetisalie.lunar.redis.run.LuaRedisRunConfigurationType"/>
    <runConfigurationProducer
            implementation="net.internetisalie.lunar.redis.run.LuaRedisRunConfigurationProducer"/>

    <!-- Coverage -->
    <coverageEngine
            implementation="net.internetisalie.lunar.coverage.LuaCoverageEngine"/>
    <coverageRunner
            implementation="net.internetisalie.lunar.coverage.LuaCoverageRunner"/>
    <programRunner
            implementation="net.internetisalie.lunar.coverage.LuaCoverageProgramRunner"/>
    <projectService
            serviceImplementation="net.internetisalie.lunar.coverage.LuaCoverageAnnotator"/>

    <!-- Coverage Report Viewer -->
    <fileType
            name="LuaCov Report"
            implementationClass="net.internetisalie.lunar.coverage.report.LuaCovReportFileType"
            fieldName="INSTANCE"
            language="LuaCovReport"
            fileNames="luacov.report.out"/>
    <lang.syntaxHighlighterFactory
            language="LuaCovReport"
            implementationClass="net.internetisalie.lunar.coverage.report.LuaCovReportSyntaxHighlighterFactory"/>
    <editorHighlighterProvider
            filetype="LuaCov Report"
            implementationClass="net.internetisalie.lunar.coverage.report.LuaCovReportEditorHighlighterProvider"/>
    <editorNotificationProvider
            implementation="net.internetisalie.lunar.coverage.report.LuaCovReportNotificationProvider"/>

    <!-- Toolchain health & diagnostics (TOOLING-07) -->
    <postStartupActivity implementation="net.internetisalie.lunar.toolchain.health.LuaToolHealthStartup" />
    <editorNotificationProvider implementation="net.internetisalie.lunar.toolchain.health.LuaToolEditorNotificationProvider" />

    <!-- RUN-08-17: covered=green / uncovered=red foregrounds for luacov.report.out -->
    <additionalTextAttributes scheme="Default" file="colorSchemes/LuaCovReportDefault.xml"/>
    <additionalTextAttributes scheme="Darcula" file="colorSchemes/LuaCovReportDarcula.xml"/>

    <!-- LuaRocks task execution / run configs (ROCKS-04) -->
    <configurationType
            implementation="net.internetisalie.lunar.rocks.run.LuaRocksRunConfigurationType"/>

    <programRunner implementation="net.internetisalie.lunar.run.LuaDebugRunner"/>
    <programRunner implementation="net.internetisalie.lunar.redis.debug.LuaRedisDebugRunner"/>
    <xdebugger.breakpointType implementation="net.internetisalie.lunar.run.LuaLineBreakpointType"/>
    <xdebugger.breakpointType implementation="net.internetisalie.lunar.redis.debug.LuaLdbBreakpointType"/>

    <!-- Inlay Hints Settings -->
    <applicationService serviceImplementation="net.internetisalie.lunar.lang.insight.hint.LuaInlayHintsSettings"/>

    <!-- Indexes -->
    <fileBasedIndex implementation="net.internetisalie.lunar.lang.indexing.LuaFileBindingsIndex"/>
    <fileBasedIndex implementation="net.internetisalie.lunar.lang.indexing.LuaDescriptionIndex"/>
    <fileBasedIndex implementation="net.internetisalie.lunar.lang.indexing.LuaCatsTypeNameIndex"/>
    <fileBasedIndex implementation="net.internetisalie.lunar.lang.indexing.LuaMemberFieldIndex"/>
    <stubIndex implementation="net.internetisalie.lunar.lang.indexing.LuaGlobalDeclarationIndex"/>
    <stubIndex implementation="net.internetisalie.lunar.lang.indexing.LuaClassNameIndex"/>
    <stubIndex implementation="net.internetisalie.lunar.lang.indexing.LuaAliasIndex"/>

    <searchEverywhereContributor implementation="net.internetisalie.lunar.lang.doc.LuaDocSearchEverywhereContributor$Factory"/>

    <!-- Notifications -->
    <notificationGroup id="notification.group.lunar.debugger"
                       displayType="BALLOON"
                       isLogByDefault="true" bundle="net.internetisalie.lunar.LuaBundle"
                       key="notification.group.lua.debugger"/>
    <notificationGroup id="notification.group.lunar.luarocks"
                       displayType="BALLOON"
                       isLogByDefault="true" bundle="net.internetisalie.lunar.LuaBundle"
                       key="notification.group.lua.luarocks"/>
    <notificationGroup id="notification.group.lunar.tools"
                       displayType="BALLOON"
                       isLogByDefault="true"/>
    <notificationGroup id="notification.group.lunar.stylua"
                       displayType="BALLOON"
                       isLogByDefault="true"/>

    <intentionAction>
      <className>net.internetisalie.lunar.lang.insight.LuaGenerateDocIntention</className>
      <category>Lua</category>
    </intentionAction>

    <intentionAction>
      <className>net.internetisalie.lunar.lang.insight.LuaStringConversionIntention</className>
      <category>Lua</category>
    </intentionAction>

    <intentionAction>
      <className>net.internetisalie.lunar.lang.insight.LuaInvertIfIntention</className>
      <category>Lua</category>
    </intentionAction>

    <intentionAction>
      <className>net.internetisalie.lunar.lang.insight.LuaCreateLocalVariableIntention</className>
      <category>Lua</category>
    </intentionAction>

    <intentionAction>
      <className>net.internetisalie.lunar.lang.insight.LuaCreateFunctionIntention</className>
      <category>Lua</category>
    </intentionAction>

    <codeInsight.lineMarkerProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaLineMarkerProvider"/>

    <codeInsight.lineMarkerProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaOverrideLineMarkerProvider"/>

    <!-- SYNTAX-05: method/function separators (honors "Show method separators") -->
    <codeInsight.lineMarkerProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaMethodSeparatorProvider"/>

    <typeHierarchyProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.hierarchy.LuaTypeHierarchyProvider"/>

    <highlightUsagesHandlerFactory
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.insight.LuaReturnHighlightUsagesHandlerFactory"/>

    <!-- Interactive Console (REPL) history root -->
    <scratch.rootType implementation="net.internetisalie.lunar.run.console.LuaConsoleRootType"/>

    <!-- Spellchecking support (EDITOR-02) -->
    <spellchecker.support
        language="Lua"
        implementationClass="net.internetisalie.lunar.lang.spellcheck.LuaSpellcheckingStrategy"/>

    <!-- TODO / FIXME indexing in Lua comments (EDITOR-03) -->
    <indexPatternBuilder
        implementation="net.internetisalie.lunar.lang.todo.LuaTodoIndexPatternBuilder"/>
    <!-- Non-layered TODO count indexer so single-line triple-dash LuaCATS doc comments are counted
         (the default highlighter-based count path misses the lazy LUACATS_COMMENT token). -->
    <todoIndexer
        filetype="Lua"
        implementationClass="net.internetisalie.lunar.lang.todo.LuaTodoIndexer"/>

    <!-- Active Lua environment widget + test-matrix results (TOOLING-05-06) -->
    <statusBarWidgetFactory id="Lunar.LuaEnvWidget"
        implementation="net.internetisalie.lunar.toolchain.ui.LuaEnvStatusBarWidgetFactory"/>
    <toolWindow id="Lunar.LuaMatrix" anchor="bottom" secondary="true" canCloseContents="true"
        factoryClass="net.internetisalie.lunar.rocks.matrix.MatrixResultsToolWindow"/>

  </extensions>

  <actions>
    <!-- Toolchain diagnostics snapshot (TOOLING-07-07) -->
    <action id="Lua.ToolchainDiagnostics"
            class="net.internetisalie.lunar.toolchain.health.LuaToolchainDiagnosticsAction"
            text="Lua: Toolchain Diagnostics"
            description="Write a Lua toolchain state snapshot to the IDE log">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action id="Lua.Console"
            class="net.internetisalie.lunar.run.console.LuaConsoleAction"
            text="Lua Console"
            description="Open an interactive Lua REPL">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <!-- Publish a rockspec to luarocks.org (ROCKS-08) -->
    <action id="Lua.Rocks.Publish"
            class="net.internetisalie.lunar.rocks.publish.PublishRockAction"
            text="Publish Rock to LuaRocks…"
            description="Upload this rockspec to luarocks.org"
            icon="net.internetisalie.lunar.lang.LuaIcons.ROCKET">
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>

    <!-- Build workspace rocks in topological order (ROCKS-10) -->
    <action id="Lua.Rocks.BuildWorkspace"
            class="net.internetisalie.lunar.rocks.build.BuildWorkspaceAction"
            text="Build Workspace (dependency order)"
            description="Build all first-party rocks with luarocks make in topological dependency order"
            icon="net.internetisalie.lunar.lang.LuaIcons.ROCKET">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
    </action>

    <action id="Lunar.ImportLuaCovReport"
            class="net.internetisalie.lunar.coverage.LuaCovReportImportAction"
            text="Import LuaCov Report..."
            description="Load coverage data from a luacov.report.out file">
      <add-to-group group-id="AnalyzePlatformMenu" anchor="last"/>
    </action>

    <!-- Native toolchain provisioning (TOOLING-04) -->
    <group id="Lunar.Toolchain.EnvironmentGroup" text="Lua Toolchain" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <action id="Lunar.Toolchain.Provision"
              class="net.internetisalie.lunar.toolchain.provision.LuaProvisionToolchainAction"
              text="Provision Lua Toolchain…"
              description="Download or build a Lua runtime, LuaRocks and dev tools into a project environment"/>
      <action id="Lunar.Toolchain.ChangeVersions"
              class="net.internetisalie.lunar.toolchain.provision.LuaChangeToolchainVersionsAction"
              text="Change Toolchain Versions…"
              description="Re-provision the active environment with different versions"/>
      <action id="Lunar.Toolchain.Recreate"
              class="net.internetisalie.lunar.toolchain.provision.LuaRecreateToolchainAction"
              text="Recreate Environment"
              description="Delete and rebuild the active environment directory"/>
      <action id="Lunar.Toolchain.Remove"
              class="net.internetisalie.lunar.toolchain.provision.LuaRemoveToolchainAction"
              text="Remove Environment"
              description="Unregister the environment's tools and optionally delete the directory"/>
      <action id="Lunar.Toolchain.RunMatrix"
              class="net.internetisalie.lunar.rocks.matrix.RunMatrixAction"
              text="Run Test Matrix…"
              description="Run the rockspec test command against every provisioned environment"/>
      <action id="Lunar.Toolchain.BatchProvision"
              class="net.internetisalie.lunar.toolchain.provision.LuaBatchProvisionToolchainsAction"
              text="Provision Version Matrix…"
              description="Provision a whole matrix of Lua versions in one action"/>
    </group>
  </actions>
</idea-plugin>
