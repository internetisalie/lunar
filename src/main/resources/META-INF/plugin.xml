<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
  <id>net.internetisalie.lunar</id>

  <!-- Public plugin name should be written in Title Case.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
  <name>Lunar</name>

  <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
  <vendor email="internetisalie@gmail.com" url="https://internetisalie.github.io">internetisalie</vendor>

  <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
       Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
  <description><![CDATA[
    Enhanced Lua support for JetBrains IDEs.
  ]]></description>

  <!-- Product and plugin compatibility requirements.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
  <depends>com.intellij.modules.platform</depends>

  <!-- Extension points defined by the plugin.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
  <extensions defaultExtensionNs="com.intellij">

    <!-- Language -->

    <fileType
            name="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaFileType"
            fieldName="INSTANCE"
            language="Lua"
            extensions="lua"/>

    <fileType
            name="Lua Workspace"
            implementationClass="net.internetisalie.lunar.lang.LuaWorkFileType"
            fieldName="INSTANCE"
            language="Lua"
            extensions="luawork"/>

    <lang.syntaxHighlighterFactory
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaSyntaxHighlighterFactory"/>

    <lang.parserDefinition
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaParserDefinition"/>

    <platform.backend.documentation.targetProvider
            order="first"
            implementation="net.internetisalie.lunar.lang.doc.LuaDocumentationTargetProvider" />

    <colorSettingsPage
            implementation="net.internetisalie.lunar.lang.syntax.LuaColorSettingsPage"/>

    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaLongStringAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaLongCommentAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaLocalBindingsAnnotator"/>
    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaGlobalBindingsAnnotator"/>

    <annotator
            language="Lua"
            implementationClass="net.internetisalie.lunar.luacats.lang.syntax.LuaCatsAnnotator"/>

    <editorHighlighterProvider
            filetype="Lua"
            implementationClass="net.internetisalie.lunar.lang.syntax.LuaEditorHighlighterProvider"/>

    <psi.referenceContributor
            language="Lua"
            implementation="net.internetisalie.lunar.lang.LuaLabelReferenceContributor"/>
    <lang.findUsagesProvider
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaLabelFindUsagesProvider"/>
    <lang.refactoringSupport
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaLabelRefactoringSupportProvider"/>

    <lang.psiStructureViewFactory language="Lua"
                                  implementationClass="net.internetisalie.lunar.lang.structure.LuaStructureViewFactory"/>

    <lang.commenter
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.LuaCommenter"/>

    <lang.formatter
            language="Lua"
            implementationClass="net.internetisalie.lunar.lang.format.LuaFormattingModelBuilder" />

    <additionalLibraryRootsProvider implementation="net.internetisalie.lunar.project.PlatformLibraryProvider"/>

    <!-- Options -->
    <applicationService
            serviceImplementation="net.internetisalie.lunar.settings.LuaApplicationSettings" />

    <applicationConfigurable
            parentId="language"
            instance="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            id="net.internetisalie.lunar.settings.LuaApplicationSettingsConfigurable"
            displayName="Lua"/>

    <projectConfigurable
            parentId="language"
            instance="net.internetisalie.lunar.settings.LuaProjectSettingsConfigurable"
            id="net.internetisalie.lunar.settings.LuaProjectSettingsConfigurable"
            displayName="Lua Project"
            nonDefaultProject="true"/>

    <configurationType
            implementation="net.internetisalie.lunar.run.LuaRunConfigurationType"/>

    <!-- Luacheck -->
    <toolWindow id="LuaCheck"
                anchor="bottom"
                icon="/icons/rocket_16.png"
                factoryClass="net.internetisalie.lunar.analysis.luacheck.LuaCheckComponents"
                canCloseContents="true"/>
    <applicationService serviceImplementation="net.internetisalie.lunar.analysis.luacheck.LuaCheckSettings"/>

    <!-- Indexes -->
    <fileBasedIndex implementation="net.internetisalie.lunar.lang.indexing.LuaFileBindingsIndex"/>

  </extensions>

  <!-- Luacheck -->
  <actions>
    <action id="lua.LuaCheck"
            text="Run LuaCheck"
            popup="true"
            icon="/icons/rocket_16.png"
            class="net.internetisalie.lunar.analysis.luacheck.LuaCheckRun">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>